   "outputs": [],
   "source": [
    "#CREATE API CLIENT\n",
    "from anthropic import Anthropic\n",
    "\n",
    "client = Anthropic(api_key=api_key)\n",
    "model = \"claude-sonnet-4-0\""
   ]
  }
